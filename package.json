{
  "name": "accesscore",
  "version": "1.0.0",
  "description": "Self-service VPN access and operations portal",
  "scripts": {
    "predev": "prisma generate",
    "dev": "next dev",
    "prebuild": "prisma generate",
    "build": "next build",
    "prestart": "prisma generate",
    "start": "next start",
    "lint": "eslint .",
    "docker:up": "docker compose -f docker/compose.yml up -d",
    "docker:down": "docker compose -f docker/compose.yml down",
    "docker:logs": "docker compose -f docker/compose.yml logs -f",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate dev",
    "db:push": "prisma db push",
    "db:seed": "npx tsx prisma/seed.ts",
    "db:studio": "prisma studio",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit"
  },
  "license": "MIT",
  "dependencies": {
    "@aws-sdk/client-ssm": "^3.1009.0",
    "@prisma/adapter-pg": "^7.5.0",
    "@prisma/client": "^7.5.0",
    "@tailwindcss/postcss": "^4.2.2",
    "@types/node": "^25.5.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "autoprefixer": "^10.4.27",
    "bcryptjs": "^3.0.3",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.1",
    "googleapis": "^171.4.0",
    "ip-cidr": "^4.0.2",
    "ldapts": "^8.1.7",
    "lucide-react": "^0.577.0",
    "next": "^16.2.0",
    "next-auth": "^4.24.13",
    "pg": "^8.20.0",
    "postcss": "^8.5.8",
    "qrcode": "^1.5.4",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "ssh2": "^1.17.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/bcryptjs": "^3.0.0",
    "@types/pg": "^8.18.0",
    "@types/qrcode": "^1.5.6",
    "@types/ssh2": "^1.15.5",
    "@vitejs/plugin-react": "^6.0.1",
    "prisma": "^7.5.0",
    "vitest": "^4.1.0"
  }
}
