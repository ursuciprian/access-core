# Database
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/openvpn_gui?schema=public"

# NextAuth
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="change-me-in-production"
ALLOW_UNSAFE_DEV_CSP="false"

# Google OAuth
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_ALLOWED_DOMAIN="yourdomain.com"

# OIDC SSO (optional)
OIDC_SSO_ENABLED="false"
OIDC_PROVIDER_NAME="Okta"
OIDC_ISSUER=""
OIDC_CLIENT_ID=""
OIDC_CLIENT_SECRET=""
OIDC_SCOPES="openid email profile"
OIDC_ALLOWED_DOMAINS=""

# Google Workspace Sync (Service Account)
GOOGLE_SERVICE_ACCOUNT_EMAIL=""
GOOGLE_SERVICE_ACCOUNT_KEY=""
GOOGLE_ADMIN_EMAIL=""

# LDAP Authentication (optional)
LDAP_ENABLED="false"
LDAP_URL=""
LDAP_BIND_DN=""
LDAP_BIND_PASSWORD=""
LDAP_BASE_DN=""
LDAP_USER_FILTER="(&(objectClass=person)(mail={{login}}))"
LDAP_EMAIL_ATTRIBUTE="mail"
LDAP_DISPLAY_NAME_ATTRIBUTE="displayName"
LDAP_GROUP_ATTRIBUTE="memberOf"
LDAP_ADMIN_GROUPS=""
LDAP_VIEWER_GROUPS=""
LDAP_SYNC_ROLES="true"
LDAP_STARTTLS="false"
LDAP_TLS_REJECT_UNAUTHORIZED="true"
LDAP_CONNECT_TIMEOUT_MS="5000"
LDAP_TIMEOUT_MS="10000"

# Feature Flags
SERVER_MANAGEMENT_ENABLED="true"
TOTP_MFA_ENABLED="true"
MFA_ONBOARDING_REQUIRED="true"
MFA_ENCRYPTION_KEY="change-me-with-a-long-random-string"
DEFAULT_VPN_SERVER_ID=""

# AWS (for SSM transport)
AWS_REGION="us-east-1"
AWS_ACCESS_KEY_ID=""
AWS_SECRET_ACCESS_KEY=""

# SSH transport (for local dev Docker OpenVPN container)
SSH_PASS_LOCAL_DEV="openvpn"
ALLOW_SSH_PASSWORD_AUTH="true"
SEED_ADMIN_EMAIL=""
SEED_ADMIN_PASSWORD=""

# Audit
AUDIT_RETENTION_DAYS="365"
